            ]
          }
        ],
        "name": "title",
        "type": "string",
        "title": "Post Title"
      },
      {
        "options": {
          "source": "title",
          "maxLength": 96
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "name": "slug",
        "type": "slug",
        "title": "URL Slug (e.g., \"how-to-fix-a-leak\")"
      },
      {
        "rows": 3,
        "name": "excerpt",
        "type": "text",
        "title": "Short Summary"
      },
      {
        "options": {
          "hotspot": true
        },
        "name": "featuredImage",
        "type": "image",
        "title": "Main Image"
      },
      {
        "of": [
          {
            "lists": [
              {
                "value": "bullet",
                "title": "Bulleted list"
              },
              {
                "value": "number",
                "title": "Numbered list"
              }
            ],
            "marks": {
              "annotations": [
                {
                  "i18nTitleKey": "inputs.portable-text.annotation.link",
                  "options": {
                    "modal": {
                      "type": "popover"
                    }
                  },
                  "fields": [
                    {
                      "validation": [
                        {
                          "level": "error",
                          "rules": [
                            {
                              "flag": "uri",
                              "constraint": {
                                "options": {
                                  "scheme": [
                                    "/^http$/",
                                    "/^https$/",
                                    "/^tel$/",
                                    "/^mailto$/"
                                  ],
                                  "allowRelative": true,
                                  "relativeOnly": false,
                                  "allowCredentials": false
                                }
                              }
                            }
                          ]
                        }
                      ],
                      "description": "A valid web, email, phone, or relative link.",
                      "name": "href",
                      "type": "url",
                      "title": "Link"
                    }
                  ],
                  "name": "link",
                  "type": "object"
                }
              ],
              "decorators": [
                {
                  "value": "strong",
                  "title": "Strong"
                },
                {
                  "value": "em",
                  "title": "Italic"
                },
                {
                  "value": "code",
                  "title": "Code"
                },
                {
                  "value": "underline",
                  "title": "Underline"
                },
                {
                  "value": "strike-through",
                  "title": "Strike"
                }
              ]
            },
            "of": [],
            "styles": [
              {
                "value": "normal",
                "title": "Normal"
              },
              {
                "value": "h1",
                "title": "Heading 1"
              },
              {
                "value": "h2",
                "title": "Heading 2"
              },
              {
                "value": "h3",
                "title": "Heading 3"
              },
              {
                "value": "h4",
                "title": "Heading 4"
              },
              {
                "value": "h5",
                "title": "Heading 5"
              },
              {
                "value": "h6",
                "title": "Heading 6"
              },
              {
                "value": "blockquote",
                "title": "Quote"
              }
            ],
            "type": "block"
          },
          {
            "options": {
              "hotspot": true
